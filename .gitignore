# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Node.js
node_modules/
npm-debug.log*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
env/

# HTML Book Bundler - INTERMEDIATE DATA (Crucial for Context Efficiency)
.bookruns/             # Temporary build stages and chapter drafts
tmp_assets/           # Temporary image downloads before localizing
assets/raw_scans/     # Extracted PDF page images (can be huge)
tmp_gen_*.py          # Dynamically generated scripts

# Playwright MCP session artifacts
.playwright-mcp/

# Book Outputs - Ignore versioned iterations to keep git clean
# This keeps only the main files, but ignores "Egyptian_Cross_Absolute_V12.html" etc.
outputs/**/V[0-9]*.html
outputs/**/*_Fixed_*.html
outputs/**/*_Interactive_*.html

# Keep the directory structure but ignore specific large artifacts
!outputs/.gitkeep
