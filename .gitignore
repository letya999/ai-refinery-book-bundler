# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Node.js
node_modules/
npm-debug.log*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
env/

# HTML Book Bundler - INTERMEDIATE DATA (Context Efficiency)
tmp_assets/           # Temporary image downloads
.bookruns/             # Build stages and chapter drafts
assets/raw_scans/     # Extracted PDF images
tmp_gen_*.py          # Dynamic scripts

# Deep nested intermediate assets in outputs
outputs/**/raw_pages/
outputs/**/assets/
outputs/**/chapters/

# Playwright MCP session artifacts
.playwright-mcp/

# Book Outputs - Keep only clean final versions
# Ignore versioned iterations and fixed bundles
outputs/**/V[0-9]*.html
outputs/**/*_Fixed_*.html
outputs/**/*_Interactive_*.html
outputs/**/*_Offline.html
outputs/**/*_Director_Cut.html
outputs/**/*_Edition.html
outputs/**/*_V9.html
outputs/**/*_Masterpiece.html

# Keep the directory structure but ignore specific large artifacts
!outputs/.gitkeep
